{
  "name": "@zethictech/plane-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Plane project management — exposes Plane API as Claude-compatible tools",
  "type": "module",
  "bin": {
    "plane-mcp-server": "dist/bin/plane-mcp-server.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "author": "ZethicTech",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/plane-mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "plane",
    "plane-api",
    "project-management",
    "issue-tracker",
    "work-items",
    "claude",
    "anthropic",
    "ai-tools",
    "llm",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZethicTech/plane-mcp-server.git"
  },
  "homepage": "https://github.com/ZethicTech/plane-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/ZethicTech/plane-mcp-server/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
